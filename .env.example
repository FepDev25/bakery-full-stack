# Panadería SaaS — Variables de entorno

# Proyecto
PROJECT_NAME=panaderia_api
API_V1_STR=/api/v1

# Base de datos
# En desarrollo local (fuera de Docker): apuntar a localhost con el puerto mapeado.
# En Docker Compose: docker-compose.yml sobreescribe POSTGRES_SERVER y POSTGRES_PORT
#   automáticamente (POSTGRES_SERVER=postgres, POSTGRES_PORT=5432).
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_USER=panaderia_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=panaderia_db

# Autenticación JWT
# SECRET_KEY: generar con `openssl rand -hex 32`
# En producción debe ser una clave aleatoria de al menos 256 bits.
SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# Lista separada por comas de los orígenes permitidos.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
# Niveles válidos: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Reglas de negocio
# LOYALTY_POINTS_RATIO: cantidad de pesos necesarios para acumular 1 punto de fidelidad.
# Ejemplo: 10 significa que cada $10 de compra = 1 punto (RN-007).
LOYALTY_POINTS_RATIO=10

# API de IA (Anthropic)
ANTHROPIC_API_KEY